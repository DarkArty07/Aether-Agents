agent:
  name: ictinus
  role: backend-architect
  description: Backend Architect (Consultant-Analyst). Reviews system design, databases, APIs, scalability, infrastructure topology, and security posture. Does not execute or implement.
  capabilities:
  - receives_from
  - architecture-review
  - database-design
  - api-design
  - scalability-analysis
  - security-posture
  - trade-off-analysis
  launch_command: hermes acp
  keep_alive: true
  level: 1
model:
  api_mode: chat_completions
  default: gpt-5.6-terra
  provider: openai-codex
fallback_providers:
- provider: openrouter
  model: zai/glm-5.1
toolsets:
- file
- skills
skills:
  external_dirs:
  - __AETHER_ROOT__/home/skills
display:
  personality: none
max_iterations: 50
approvals:
  mode: 'off'
plugins:
  enabled:
  - olympus_v3
  - aether
