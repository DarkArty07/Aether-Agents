agent:
  name: ariadna
  role: context-curator
  description: Context Curator. Reads aether.db, synthesizes project state, writes .aether/CONTEXT.md for incoming Daimon sessions.
  capabilities:
  - receives_from
  - context-curation
  - synthesis
  launch_command: hermes acp
  keep_alive: true
  level: 1
model:
  api_mode: chat_completions
  default: gpt-5.6-terra
  provider: openai-codex
fallback_providers:
- provider: openrouter
  model: moonshotai/kimi-k2
toolsets:
- file
- skills
skills:
  external_dirs:
  - __AETHER_ROOT__/home/skills
display:
  personality: none
max_iterations: 50
approvals:
  mode: 'off'
plugins:
  enabled:
  - olympus_v3
  - aether
