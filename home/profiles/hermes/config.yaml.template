# Hermes Orchestrator — Aether Agents profile config
# Template: run scripts/configure.sh to generate config.yaml from this file.
# Replaces __AETHER_ROOT__ and __HERMES_PYTHON__ with machine-specific paths.

agent:
  name: hermes
  role: orchestrator
  description: "Technical Lead y arquitecto del equipo. Investiga, diseña, orquesta y decide."
  capabilities:
    - talk_to
    - discover
    - delegate_task
    - all
  launch_command: "hermes acp"
  keep_alive: true
  max_turns: 150
  gateway_timeout: 1800

model:
  default: glm-5.1
  provider: zai
  base_url: https://api.z.ai/api/coding/paas/v4

platform_toolsets:
  cli:
    - clarify
    - code_execution
    - delegation
    - file
    - memory
    - session_search
    - skills
    - terminal
    - todo
    - web

skills:
  external_dirs:
    - __AETHER_ROOT__/skills

# Olympus MCP server — connects Hermes to Daimons via ACP
mcp_servers:
  olympus:
    command: __HERMES_PYTHON__
    args:
      - -m
      - olympus.server
    env:
      AETHER_HOME: __AETHER_ROOT__/home
      PYTHONPATH: __AETHER_ROOT__/src
    enabled: true

web:
  backend: exa

display:
  # IMPORTANT: Set personality to "none" for Aether Agents.
  # The personality overlay conflicts with SOUL.md agent identities.
  # See docs/guides/CONFIGURATION.md for details.
  personality: none
  show_reasoning: false
  streaming: false

delegation:
  model: qwen3.6-plus
  provider: opencode-go
  base_url: https://opencode.ai/zen/go/v1
  api_key: ''  # Resolved from OPENCODE_GO_API_KEY env var
  inherit_mcp_toolsets: true
  max_iterations: 50
  child_timeout_seconds: 600
  reasoning_effort: ''
  max_concurrent_children: 3
  max_spawn_depth: 1
  orchestrator_enabled: true

context:
  engine: compressor
