agent:
  name: hefesto
  role: senior-developer
  description: Senior Developer. Implements specs, code reviews, integrates, debugs. Receives atomic tasks from Hermes — does not decompose or delegate.
  capabilities:
  - receives_from
  - implementation
  - code-review
  - integration
  - debugging
  launch_command: hermes acp
  keep_alive: true
model:
  api_mode: chat_completions
  default: gpt-5.6-terra
  provider: openai-codex
fallback_providers:
- provider: openrouter
  model: deepseek/deepseek-chat-v3-0324
toolsets:
- terminal
- file
- skills
skills:
  external_dirs:
  - __AETHER_ROOT__/home/skills
display:
  personality: none
max_iterations: 80
approvals:
  mode: 'off'
plugins:
  enabled:
  - olympus_v3
  - aether
