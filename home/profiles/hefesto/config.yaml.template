# Template — run scripts/setup.sh to generate config.yaml. Replaces __AETHER_ROOT__ and __HERMES_PYTHON__.

# Hefesto configuration — Aether Agents Daimon (Level 2)

# Agent discovery field — Olympus reads this to register the Daimon
agent:
  name: hefesto
  role: senior-developer
  description: "Senior Developer y Tech Lead de implementación. Descompone por rol, delega, revisa, integra."
  capabilities:
    - receives_from
    - delegate_task
    - implementation
    - code-review
    - integration
    - debugging
    - estimation
  launch_command: "hermes acp"
  keep_alive: true

# Model configuration
model:
  api_mode: chat_completions
  default: glm-5.1
  provider: opencode-go
  base_url: https://opencode.ai/zen/go/v1

# Toolsets — implementation tools only
toolsets:
  - terminal
  - file
  - search_files
  - patch
  - execute_code
  - delegate_task
  - skills

skills:
  external_dirs:
    - __AETHER_ROOT__/home/skills

# Session settings
# Personality overlay must be "none" — prevents kawaii default from overwriting SOUL.md
display:
  personality: none

max_iterations: 80

# Auto-approve commands — Daimons have no interactive user for approval prompts
approvals:
  mode: 'off'

# Auto-approve subagent commands — hefesto delegates to Ergates
delegation:
  subagent_auto_approve: true
# Olympus v3 observability plugin
plugins:
  enabled:
    - olympus_v3
    - aether