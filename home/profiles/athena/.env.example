# Athena (Worker Daimon) — API Configuration
# Copy this file to .env and uncomment the provider you want to use.
# Note: This Daimon can use a DIFFERENT provider than Hermes.
# See docs/guides/PROVIDERS.md for full configuration options.

# --- OpenAI ---
# OPENAI_API_KEY=sk-your-key-here

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- OpenRouter (aggregates multiple providers) ---
# OPENROUTER_API_KEY=sk-or-your-key-here

# --- Zhipu AI (GLM models) ---
# GLM_API_KEY=your-key-here

# --- Moonshot (Kimi models) ---
# MOONSHOT_API_KEY=your-key-here

# --- MiniMax ---
# MINIMAX_API_KEY=your-key-here

# --- DeepSeek ---
# DEEPSEEK_API_KEY=your-key-here

# --- Local (Ollama) ---
# No API key needed. Set base_url in config.yaml to http://localhost:11434
