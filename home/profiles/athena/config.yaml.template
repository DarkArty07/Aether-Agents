agent:
  name: athena
  role: security-analyst
  description: Security Analyst (Consultant-Analyst). Threat modeling, security review, dependency audit. Reads code, never implements.
  capabilities:
  - receives_from
  - threat-modeling
  - security-review
  launch_command: hermes acp
  keep_alive: true
model:
  api_mode: chat_completions
  default: gpt-5.6-terra
  provider: openai-codex
fallback_providers:
- provider: openrouter
  model: moonshotai/kimi-k2
toolsets:
- file
- skills
skills:
  external_dirs:
  - __AETHER_ROOT__/home/skills
display:
  personality: none
max_iterations: 50
approvals:
  mode: 'off'
plugins:
  enabled:
  - olympus_v3
  - aether
