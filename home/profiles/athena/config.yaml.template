# Template — run scripts/setup.sh to generate config.yaml. Replaces __AETHER_ROOT__ and __HERMES_PYTHON__.

# Athena configuration — Aether Agents Daimon (Consultant-Analyst)

# Agent discovery field — Olympus reads this to register the Daimon
agent:
  name: athena
  role: security-analyst
  description: "Security Analyst (Consultant-Analyst). Threat modeling, security review, dependency audit. Reads code, never implements."
  capabilities:
    - receives_from
    - threat-modeling
    - security-review
  launch_command: "hermes acp"
  keep_alive: true

# Model configuration
model:
  api_mode: chat_completions
  default: kimi-k2.6
  provider: opencode-go
  base_url: https://opencode.ai/zen/go/v1

# Toolsets — each has a documented justification
toolsets:
  - file        # read_file, search_files for code audit; write_file/patch available but SOUL.md prohibits use (Consultant-Analyst)
  - terminal    # git log, grep, find, wc — secondary audit tool for security checks
  - skills     # load athena-security-checklists and other references on-demand

skills:
  external_dirs:
    - __AETHER_ROOT__/home/skills

# Session settings
# Personality overlay must be "none" — prevents kawaii default from overwriting SOUL.md
display:
  personality: none

max_iterations: 50

# Auto-approve commands — Daimons have no interactive user for approval prompts
approvals:
  mode: 'off'
# Olympus v3 observability plugin
plugins:
  enabled:
    - olympus_v3
    - aether