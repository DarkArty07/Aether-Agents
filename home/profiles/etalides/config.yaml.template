agent:
  name: etalides
  role: researcher
  description: Researcher — internet and codebase contact. Deep investigation of frameworks, products, APIs, and codebases. Reports data only, never opinions.
  capabilities:
  - receives_from
  - web-search
  - web-extract
  - code-search
  - link-budget
  - structured-output
  launch_command: hermes acp
  keep_alive: true
model:
  api_mode: chat_completions
  default: gpt-5.6-terra
  provider: openai-codex
fallback_providers:
- provider: openrouter
  model: deepseek/deepseek-chat-v3-0324
web:
  backend: exa
toolsets:
- web
- browser
- file
- terminal
link_budget:
  max_links: 10
  fast_mode: 5
skills:
  external_dirs:
  - __AETHER_ROOT__/home/skills
display:
  personality: none
max_iterations: 80
approvals:
  mode: 'off'
plugins:
  enabled:
  - olympus_v3
  - aether
