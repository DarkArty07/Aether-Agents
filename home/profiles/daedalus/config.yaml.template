agent:
  name: daedalus
  role: consultant-creator
  description: Consultant-Creator — UX/UI Designer. User flows, layout specs, design systems, prototypes. Consults and prototypes — does not implement production code.
  capabilities:
  - receives_from
  - ux-design
  - prototyping
  - design-systems
  - accessibility-review
  launch_command: hermes acp
  keep_alive: true
  level: 1
model:
  api_mode: chat_completions
  default: gpt-5.6-terra
  provider: openai-codex
fallback_providers:
- provider: openrouter
  model: minimax/mimo-v2-omni
toolsets:
- file
- terminal
- skills
skills:
  external_dirs:
  - __AETHER_ROOT__/home/skills
display:
  personality: none
max_iterations: 50
approvals:
  mode: 'off'
plugins:
  enabled:
  - olympus_v3
  - aether
