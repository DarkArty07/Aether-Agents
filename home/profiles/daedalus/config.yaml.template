# Template — run scripts/setup.sh to generate config.yaml. Replaces __AETHER_ROOT__ and __HERMES_PYTHON__.

# Daedalus configuration — Aether Agents Daimon (Level 1 Consultant)

# Agent discovery field — Olympus reads this to register the Daimon
agent:
  name: daedalus
  role: frontend-developer
  description: "Frontend Developer & UX Designer. Component architecture, performance, accessibility, user flows. Prototypes and specifies — does not implement production backend."
  capabilities:
    - receives_from
    - ux-design
    - prototyping
    - design-systems
    - accessibility-review
    - frontend-development
    - performance-optimization
  launch_command: "hermes acp"
  keep_alive: true
  level: 1

# Model configuration
model:
  default: mimo-v2-omni
  provider: opencode-go
  base_url: https://opencode.ai/zen/go/v1

# Toolsets — prototyping and design tools
toolsets:
  - terminal
  - file
  - search_files
  - patch
  - execute_code
  - skills

skills:
  external_dirs:
    - __AETHER_ROOT__/home/skills

# Session settings
# Personality overlay must be "none" — prevents kawaii default from overwriting SOUL.md
display:
  personality: none

max_iterations: 50

# Auto-approve commands — Daimons have no interactive user for approval prompts
approvals:
  mode: 'off'
# Olympus v3 observability plugin
plugins:
  enabled:
    - olympus_v3
    - aether