# Aether Agents — Orchestrator API Configuration
# Copy this file to .env or run scripts/setup.sh to auto-generate.
# At minimum, configure the provider(s) your agent model uses.
# See docs/guides/INSTALLATION.md §6.1 for the full reference.

# --- OpenAI ---
# OPENAI_API_KEY=sk-...here

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...here

# --- OpenRouter (aggregates multiple providers) ---
# OPENROUTER_API_KEY=sk-or-...here

# --- DeepSeek ---
# DEEPSEEK_API_KEY=sk-...here

# --- Zhipu AI (GLM models) ---
# GLM_API_KEY=your-key-here

# --- Moonshot (Kimi models) ---
# MOONSHOT_API_KEY=your-key-here

# --- MiniMax ---
# MINIMAX_API_KEY=your-key-here

# --- AI Prime Tech ---
# AIPRIMETECH_API_KEY=your-key-here

# --- OpenCode (default orchestrator provider) ---
# OPENCODE_GO_API_KEY=sk-...here

# --- Local (Ollama) ---
# No API key needed. Set base_url in config.yaml to http://localhost:11434
