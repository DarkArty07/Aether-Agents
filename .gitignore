# ===========================
# Aether Agents — .gitignore
# ===========================

# --- Secrets (NEVER commit) ---
.env
*.env
!.env.example
!env.base.example
shared/env.base

# --- Runtime (auto-generated) ---
home/sessions/
home/logs/
home/plugins/
home/.cache/
**/sessions/
**/request_dump*
**/logs/

# --- Auth and model caches (contain API keys/tokens) ---
**/auth.json
**/models_dev_cache.json

# --- Hermes runtime files ---
**/state.db
**/auth.lock
**/.skills_prompt_snapshot.json
**/.hermes_history
**/checkpoints/
home/skills/.hub/

# --- Hermes bundled skills (auto-expanded by framework, ~8MB) ---
# Each profile gets bundled skills on first run. Only custom skills
# (aether-agents/) should be committed.
home/profiles/hermes/skills/apple/
home/profiles/hermes/skills/autonomous-ai-agents/
home/profiles/hermes/skills/creative/
home/profiles/hermes/skills/data-science/
home/profiles/hermes/skills/devops/
home/profiles/hermes/skills/diagramming/
home/profiles/hermes/skills/dogfood/
home/profiles/hermes/skills/domain/
home/profiles/hermes/skills/email/
home/profiles/hermes/skills/feeds/
home/profiles/hermes/skills/gaming/
home/profiles/hermes/skills/gifs/
home/profiles/hermes/skills/github/
home/profiles/hermes/skills/inference-sh/
home/profiles/hermes/skills/mcp/
home/profiles/hermes/skills/media/
home/profiles/hermes/skills/mlops/
home/profiles/hermes/skills/note-taking/
home/profiles/hermes/skills/productivity/
home/profiles/hermes/skills/red-teaming/
home/profiles/hermes/skills/research/
home/profiles/hermes/skills/smart-home/
home/profiles/hermes/skills/social-media/
home/profiles/hermes/skills/software-development/
home/profiles/hermes/skills/.bundled_manifest

# --- Hermes auto-expanded profile config (generated by configure.sh) ---
home/profiles/hermes/config.yaml

# --- Hermes runtime dirs ---
home/profiles/hermes/bin/
home/profiles/hermes/sandboxes/
home/profiles/hermes/cron/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Eter project state (local only) ---
.eter/

# --- Claude Code (dev tool, not project) ---
.claude/

# --- Development artifacts ---
PROMPT_OPUS.md
CLAUDE.md
docs/sesiones/
docs/setup/
