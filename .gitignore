# ===========================
# Aether Agents — .gitignore
# ===========================

# --- Secrets (NEVER commit) ---
.env
*.env
!.env.example
honcho-server/.env

# --- Runtime (auto-generated) ---
home/sessions/
home/logs/
home/plugins/
home/.cache/
home/.olympus/
home/active_profile
home/bin/
**/sessions/
**/request_dump*
**/logs/

# --- Auth and model caches ---
**/auth.json
**/models_dev_cache.json

# --- Hermes runtime files ---
**/state.db
**/auth.lock
**/.skills_prompt_snapshot.json
**/.hermes_history
**/checkpoints/
**/interrupt_debug.log
home/skills/.hub/

# --- Profile skills directories (skills loaded via external_dirs from home/skills/) ---
home/profiles/*/skills/*
!home/profiles/*/skills/.gitkeep

# --- Per-profile bundled manifests (auto-generated) ---
**/.bundled_manifest

# --- Per-profile live config (generated from templates) ---
home/profiles/ariadna/config.yaml
home/profiles/hefesto/config.yaml
home/profiles/etalides/config.yaml
home/profiles/athena/config.yaml
home/profiles/daedalus/config.yaml
home/profiles/ictinus/config.yaml

# --- Per-profile agent hooks (local for security) ---
home/profiles/*/agent-hooks/

# --- Per-profile runtime state ---
home/profiles/*/memories/
home/profiles/*/research/
home/profiles/*/.update_check
home/profiles/*/channel_directory.json
home/profiles/*/gateway.lock
home/profiles/*/gateway.pid
home/profiles/*/gateway_state.json
home/profiles/*/ollama_cloud_models_cache.json

# --- Per-profile runtime dirs ---
home/profiles/*/bin/
home/profiles/*/sandboxes/
home/profiles/*/cron/
home/profiles/*/lsp/
home/profiles/*/pastes/
home/profiles/*/spawn-trees/
home/profiles/*/processes.json
home/profiles/*/skins
home/profiles/*/cache/
home/profiles/*/hindsight/
home/profiles/*/.restart_last_processed.json
home/kanban.db
home/profiles/*/kanban.db
home/profiles/*/honcho.json
home/profiles/*/.env.bak*

# --- Home-level runtime (not per-profile) ---
home/config.yaml
home/memories/
home/hindsight/
home/agent-hooks/
home/pastes/
home/cron/
home/sandboxes/
home/shell-hooks-allowlist.json
home/shell-hooks-allowlist.json.lock
home/skills/.curator_state
home/skills/.curator_backups/

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/

# --- Hermes venv (pip install target) ---
home/.venv-hermes/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Prometeo (personal assistant — private) ---
home/profiles/prometeo/

# --- Project state (local only) ---
.eter/
.hermes/
**/.olympus_checkpoints.db*
**/state.db-shm
**/state.db-wal

# --- Research (local findings, not shared) ---
home/research/

# --- Claude Code (dev tool) ---
.claude/

# --- Development artifacts ---
PROMPT_OPUS.md
CLAUDE.md
docs/sesiones/
docs/setup/

# Auto-generated observations
.aether/

# --- Pi Agent PID-suffixed session files (concurrent Daimon isolation) ---
**/.olympus_session
**/.olympus_session.*
**/.olympus_db_path
**/.olympus_db_path.*
**/.aether_home
**/.aether_home.*
**/.clean_shutdown

# --- Subagent-driven-development runtime ---
home/skills/software-development/subagent-driven-development/references/

# --- Skills usage tracking (local only) ---
home/skills/.usage.json
home/skills/.usage.json.lock
home/.olympus_v3.db
home/channel_directory.json
home/gateway.lock
home/gateway.pid
home/gateway_state.json

# --- Graphify output (generated graphs, reports, caches) ---
graphify-out/

# Runtime caches (not version-controlled)
home/models_dev_cache.json
home/ollama_cloud_models_cache.json
home/state.db*
home/.hermes_history
home/.skills_prompt_snapshot.json
