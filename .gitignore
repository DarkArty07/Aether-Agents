# ===========================
# Aether Agents — .gitignore
# ===========================

# --- Secrets (NEVER commit) ---
.env
*.env
!.env.example
!env.base.example
shared/env.base

# --- Runtime (auto-generated) ---
home/sessions/
home/logs/
home/plugins/
home/.cache/
**/sessions/
**/request_dump*
**/logs/

# --- Auth and model caches (contain API keys/tokens) ---
**/auth.json
**/models_dev_cache.json

# --- Hermes runtime files ---
**/state.db
**/auth.lock
**/.skills_prompt_snapshot.json
home/skills/.hub/

# --- Hermes auto-expanded profile config (generated by hermes on first run) ---
# Use config.yaml.template as the source of truth; configure.sh generates this.
home/profiles/hermes/config.yaml

# --- WSL local copy (runtime only) ---
# The WSL copy at ~/Aether-Agents/ is a runtime working copy
# Only the Windows repo at /mnt/c/.../Aether-Agents/ is the git source

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
venv/
.venv/

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Eter project state (local only) ---
.eter/