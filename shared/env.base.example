# =============================================================================
# Aether Agents — Shared Environment Variables (TEMPLATE)
# Copy to env.base and fill with real values.
# NEVER commit env.base with real keys — only this example file.
# =============================================================================

# ── LLM Providers ────────────────────────────────────────────────
# z.ai (GLM) — Americas endpoint
GLM_API_KEY=your_zai_api_key_here

# OpenCode Go — unified LLM proxy
OPENCODE_GO_API_KEY=your_opencode_api_key_here
OPENCODE_GO_BASE_URL=https://opencode.ai/zen/go/v1

# ── Model per Daimon ─────────────────────────────────────────────
# Hermes (Orchestrator)    → glm-5.1 via z.ai
# Ariadna (Project Manager) → kimi-k2.5 via opencode-go
# Daedalus (UX/UI)          → mimo-v2-omni via opencode-go
# Hefesto (Senior Dev)      → glm-5.1 via opencode-go
# Etalides (Researcher)     → minimax-m2.7 via opencode-go
# Athena (Security)         → kimi-k2.6 via opencode-go

# ── Aether Home ─────────────────────────────────────────────────
AETHER_HOME=/path/to/Aether-Agents/home